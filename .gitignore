# ═══════════════════════════════════════════
# Cena Platform — .gitignore
# ═══════════════════════════════════════════

# ── Tooling (Ruflo agents, hooks, MCP config — committed for reproducibility) ──
# .claude/        ← COMMITTED (agent definitions, helpers, settings)
# .claude-flow/   ← COMMITTED (swarm config, sessions, data)
# .swarm/         ← COMMITTED (swarm state)
# .mcp.json       ← COMMITTED (MCP server config)

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db

# ── Secrets (NEVER commit) ──
.env
.env.*
*.env
secrets/
credentials.json

# ── Build artifacts ──
node_modules/
build/
dist/
bin/
obj/
*.dll
*.exe

# ── .NET ──
*.user
*.suo
packages/

# ── Python ──
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── Flutter ──
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock

# ── Firebase ──
firebase-debug.log
.firebase/

# ── Logs ──
*.log
logs/
