# ═══════════════════════════════════════════
# Cena Platform — .gitignore
# ═══════════════════════════════════════════

# ── Tooling (regenerated by ruflo init) ──
.claude/
.claude-flow/
.swarm/
.mcp.json

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db

# ── Secrets (NEVER commit) ──
.env
.env.*
*.env
secrets/
credentials.json

# ── Build artifacts ──
node_modules/
build/
dist/
bin/
obj/
*.dll
*.exe

# ── .NET ──
*.user
*.suo
packages/

# ── Python ──
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── Flutter ──
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock

# ── Firebase ──
firebase-debug.log
.firebase/

# ── Logs ──
*.log
logs/
