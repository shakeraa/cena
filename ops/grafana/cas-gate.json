{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus scrape target for the Cena Admin + Actor hosts",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "CAS Verification Gate — ingestion-time correctness oracle (ADR-0002, ADR-0032). Panels pair 1:1 with alerts in docs/ops/alerts/cas-gate.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Verifications per second, split by result (verified/failed/unverifiable/error) and engine.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (result, engine) (rate(cena_cas_verification_total[5m]))",
          "legendFormat": "{{result}} ({{engine}})",
          "refId": "A"
        }
      ],
      "title": "CAS Verifications (rate, by result × engine)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Latency percentiles per engine.",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, engine) (rate(cena_cas_verification_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{engine}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, engine) (rate(cena_cas_verification_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{engine}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, engine) (rate(cena_cas_verification_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{engine}}",
          "refId": "C"
        }
      ],
      "title": "CAS Verification Latency (per-engine)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Circuit breaker state per engine: 0 = closed, 1 = half-open, 2 = open. See alert CasCircuitBreakerOpen.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Closed", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Half-open", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "OPEN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal" },
      "targets": [
        {
          "expr": "max by (engine) (cena_cas_circuit_breaker_state)",
          "legendFormat": "{{engine}}",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker State",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rejection rate over 10 minutes. Alert CasRejectionRateHigh fires at > 10%.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "sum(rate(cena_questions_rejected_cas_total[10m])) / clamp_min(sum(rate(cena_cas_verification_total[10m])), 1)",
          "legendFormat": "rejection rate",
          "refId": "A"
        }
      ],
      "title": "CAS Rejection Rate (10m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Verified bindings ÷ published math questions. RDY-040 startup check refuses to boot when this drops below 1.0 in Enforce mode.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 1.0 }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "cena_cas_binding_coverage_ratio",
          "legendFormat": "coverage",
          "refId": "A"
        }
      ],
      "title": "Binding Coverage Ratio (RDY-040)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "CAS gate rollout mode: 0=Off, 1=Shadow, 2=Enforce.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Off", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "Shadow", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "Enforce", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 14 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "max(cena_cas_gate_mode)",
          "legendFormat": "mode",
          "refId": "A"
        }
      ],
      "title": "Gate Mode",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total operator overrides (cumulative). Every override also triggers a Slack notification via RDY-045.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 14 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "sum(cena_cas_override_total)",
          "legendFormat": "overrides",
          "refId": "A"
        }
      ],
      "title": "CAS Override Count (lifetime)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Idempotency cache hit rate — reassures that callers who run the gate twice (e.g. QuestionBankService two-read pattern) hit the cache and do not double-charge the sidecar.",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "sum(rate(cena_cas_cache_hit_total[5m]))",
          "legendFormat": "cache hit/s",
          "refId": "A"
        }
      ],
      "title": "Idempotency Cache Hits (rate)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cena", "cas", "adr-0002", "adr-0032"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Cena — CAS Verification Gate",
  "uid": "cena-cas-gate",
  "version": 1,
  "weekStart": ""
}
