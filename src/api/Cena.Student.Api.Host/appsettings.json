{
  "ConnectionStrings": {
    "Redis": "localhost:6380",
    "NATS": "nats://localhost:4222"
    // FIND-sec-006: PostgreSQL connection string removed. Use CENA_POSTGRES_CONNECTION env var
    // or ConnectionStrings:PostgreSQL in appsettings.Development.json (git-ignored).
  },
  "Firebase": {
    "ProjectId": "cena-platform"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5051"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Using": ["Serilog.Sinks.Console"],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"],
    "Properties": {
      "Application": "Cena.Student.Api.Host"
    }
  },
  "AllowedHosts": "*"
}
