{
  "Marten": {
    "AutoCreate": "CreateOrUpdate"
  },
  "Cena": {
    "StuckClassifier": {
      "Enabled": true,
      "AnonSalt": "cena-dev-only-salt-not-for-prod",
      "HeuristicSkipLlmThreshold": 0.7,
      "MinActionableConfidence": 0.6,
      "ClassifierVersion": "v1.0.0-dev",
      "RetentionDays": 30,
      "HintAdjustmentEnabled": true,
      "HintAdjustmentTimeoutMs": 500,
      "HintAdjustmentMinConfidence": 0.65
    }
  },
  "Ingestion": {
    "CloudWatchDirs": [ "./ingest-local" ],
    "MaxBatchFiles": 1000,
    "MaxBatchBytes": 10737418240,
    "S3": {
      "Enabled": true,
      "Region": "us-east-1",
      "AllowedBuckets": [ "cena-ingest-dev" ],
      "ServiceUrl": "http://localhost:4566",
      "ForcePathStyle": true,
      "AccessKey": "test",
      "SecretKey": "test",
      "PageSize": 1000
    }
  }
}
