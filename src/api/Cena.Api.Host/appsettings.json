{
  "ConnectionStrings": {
    "Redis": "localhost:6380",
    "NATS": "nats://localhost:4222"
    // FIND-sec-006: PostgreSQL connection string removed. Use CENA_POSTGRES_CONNECTION env var
    // or ConnectionStrings:PostgreSQL in appsettings.Development.json (git-ignored).
  },
  "Firebase": {
    "ProjectId": "cena-platform",
    "ServiceAccountKeyPath": "../../scripts/firebase/service-account-key.json"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5174", "http://localhost:5175", "https://admin.cena.edu"]
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5050"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "Using": ["Serilog.Sinks.Console"],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "Cena.Api.Host"
    }
  },
  "Ingestion": {
    "CloudWatchDirs": ["/Users/shaker/edu-apps/cena/data/ingest"]
  },
  "AllowedHosts": "*"
}
