# iconify dist files — generated by `npm run build:icons` (postinstall).
# Committed so fresh worktrees that symlink node_modules (and therefore skip
# postinstall) don't fail lint with "Unable to resolve path to module
# './icons.css'". Regenerate via `npm run build:icons` when tabler icons
# are updated.
# src/plugins/iconify/icons.css

# MSW service worker — generated by `npm run msw:init` (postinstall).
# FIND-arch-017: now gitignored. MSW is dev-only; the file is regenerated
# by postinstall/predev and should NOT ship in production builds.
# Fresh worktrees that need MSW for dev run `npm run msw:init` via the
# postinstall guard. The predev-check.mjs script also validates its
# presence before starting the dev server.
public/mockServiceWorker.js

# Env files
.env*
!.env.example

# STU-W-01 test tooling artifacts (keep screenshots, drop traces)
test-results/stuw01/playwright-artifacts/
