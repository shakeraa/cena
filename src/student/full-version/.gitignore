# iconify dist files — generated by `npm run build:icons` (postinstall).
# Committed so fresh worktrees that symlink node_modules (and therefore skip
# postinstall) don't fail lint with "Unable to resolve path to module
# './icons.css'". Regenerate via `npm run build:icons` when tabler icons
# are updated.
# src/plugins/iconify/icons.css

# MSW service worker — generated by `npm run msw:init` (postinstall).
# Committed for the same reason as icons.css above: fresh worktrees that
# symlink node_modules skip postinstall and would otherwise hit
# "[MSW] Failed to register the Service Worker" at runtime because the
# SPA fallback serves text/html instead of the worker script.
# public/mockServiceWorker.js

# Env files
.env*
!.env.example

