VITE_MAPBOX_ACCESS_TOKEN=

# Locale gate for Hebrew. FIND-ux-014 / user rule 2026-03-27:
# Hebrew is hideable outside Israel. Set to "true" for Israeli
# tenant builds; leave unset/empty everywhere else.
VITE_ENABLE_HEBREW=false

# ── Firebase Auth (cena-platform project) ──
# Required for production and real-auth dev mode.
# Copy to .env and fill in values from the Firebase console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=cena-platform.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cena-platform
VITE_FIREBASE_STORAGE_BUCKET=cena-platform.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Auth Emulator (optional, for local dev with emulated auth) ──
# Uncomment to connect to Firebase Auth emulator instead of production.
# VITE_FIREBASE_AUTH_EMULATOR_HOST=http://127.0.0.1:9099

# ── Mock Auth (dev only) ──
# Set to 'true' to bypass Firebase and use the mock auth stub.
# This allows development without Firebase credentials.
# Default: not set (real Firebase Auth is used).
# VITE_USE_MOCK_AUTH=true

# ── Backend API ──
VITE_API_BASE_URL=/api
