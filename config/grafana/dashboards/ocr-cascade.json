{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "title": "Cena OCR Cascade — ADR-0033 / RDY-OCR-OBSERVABILITY",
  "tags": ["cena", "ocr", "cascade", "adr-0033"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "regex": "",
        "current": { "text": "Prometheus", "value": "${DS_PROMETHEUS}" }
      },
      {
        "name": "surface",
        "label": "Surface",
        "type": "custom",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "StudentInteractive,AdminBatch,All",
        "current": { "text": "All", "value": "All" },
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Cascade success rate (last 5m)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.97 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ocr_cascade_requests_total{outcome=\"ok\"}[5m])) / clamp_min(sum(rate(ocr_cascade_requests_total[5m])), 1)",
          "legendFormat": "ok / total"
        }
      ]
    },
    {
      "id": 2,
      "title": "Cascade total latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, surface) (rate(ocr_cascade_total_latency_milliseconds_bucket[5m])))",
          "legendFormat": "p50 {{surface}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, surface) (rate(ocr_cascade_total_latency_milliseconds_bucket[5m])))",
          "legendFormat": "p95 {{surface}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, surface) (rate(ocr_cascade_total_latency_milliseconds_bucket[5m])))",
          "legendFormat": "p99 {{surface}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Fallback firing rate (Mathpix / Gemini)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (fallback, reason) (rate(ocr_cascade_fallbacks_fired_total[5m]))",
          "legendFormat": "{{fallback}} / {{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "CAS verdict distribution (L5)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verdict) (rate(ocr_cas_verdicts_total[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Review queue depth (flagged rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "description": "Rate of cascade results routed to the human-review queue, by surface + reason. Queue depth itself is derived from this rate minus the curator drain rate; shown here as the arrival rate.",
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (surface, reason) (rate(ocr_human_review_flagged_total[5m]))",
          "legendFormat": "{{surface}} / {{reason}}"
        }
      ]
    }
  ]
}
