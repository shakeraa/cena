  "panels": [
    {
      "title": "Active Actors (Activations - Passivations)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(cena_student_activations_total[5m])",
          "legendFormat": "activations/s",
          "refId": "A"
        },
        {
          "expr": "rate(cena_student_passivations_total[5m])",
          "legendFormat": "passivations/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6400 },
              { "color": "red", "value": 8000 }
            ]
          }
        }
      }
    },
    {
      "title": "Event Persist Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(cena_student_event_persist_ms_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(cena_student_event_persist_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
