# ============================================================================
# Cena CAS Gate — environment-variable surface (ADR-0032)
# CAS-DEFERRED-OPS: single authoritative list of env vars that gate the
# CAS pipeline in both docker-compose and k8s deployments.
#
# Copy to cas-gate.env (git-ignored) and `source` it or pass to docker
# compose via `--env-file config/cas-gate/cas-gate.env`.
# ============================================================================

# Gate mode — controls whether failed CAS verdicts block a question.
# Values:
#   Off      — CAS never runs. Pre-CAS legacy behavior. (Only for break-glass.)
#   Shadow   — CAS runs, logs + meters the verdict, does NOT block. (Staging default.)
#   Enforce  — CAS runs, failed verdicts block persistence. (Production default.)
#
# Production rollout flips staging → Enforce first, waits 24 h, then prod.
# See tasks/readiness/done/RDY-036-cas-production-hardening.md.
CENA_CAS_GATE_MODE=Shadow

# Super-admin CAS override endpoint (POST /api/admin/questions/{id}/cas-override).
# Values: "true" | "false" (default false).
# When false the endpoint returns 503 CAS_OVERRIDE_DISABLED. Flip to true
# only for named incidents; pair with a ticket reference (the endpoint
# requires a ≥20-char reason and a linked ticket id).
CENA_CAS_OVERRIDE_ENABLED=false

# Dev/test-only pre-pilot DB wipe (Cena.Tools.DbAdmin WipeQuestionsCommand).
# Values: "true" | "false" (default false).
# When true AND the operator passes `--confirm "I UNDERSTAND"` the tool
# will truncate QuestionState streams. NEVER set this in production.
CENA_ALLOW_PREPILOT_WIPE=false
